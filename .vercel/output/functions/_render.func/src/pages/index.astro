---
// index.astro - Main page assembling all sections
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Specs from "../components/Specs.astro";
import Services from "../components/Services.astro";
import About from "../components/About.astro";
import Reviews from "../components/Reviews.tsx";
import Contact from "../components/Contact.astro";
import FinalCTA from "../components/FinalCTA.astro";
import WhatsAppButton from "../components/WhatsAppButton.tsx";
---

<Layout title="Soporte Técnico Profesional | PC, Notebooks, Redes">
  <Hero />

  <Services />

  <About />

  <section
    id="resenas"
    class="relative pt-12 pb-24 sm:pt-16 sm:pb-24 dark:bg-[#050B14] bg-white transition-colors duration-300 overflow-hidden scroll-mt-24"
  >
    {/* Local tech grid overlay */}
    <div
      class="absolute inset-0 z-0 pointer-events-none select-none dark:block hidden"
      style="background-image: linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 50px 50px;"
    >
    </div>
    {/* Subtle technical glow orb behind scorecard */}
    <div
      class="absolute top-1/2 left-10 -translate-y-1/2 w-[450px] h-[450px] bg-blue-600/[0.02] rounded-full blur-[130px] pointer-events-none z-0"
    >
    </div>
    <div class="mx-auto max-w-[90rem] px-8 sm:px-12 lg:px-20 relative z-10">
      {/* Editorial Header Section */}
      <div
        data-reveal
        class="border-b border-[var(--section-divider)] pb-10 mb-12 flex flex-col md:flex-row md:items-end md:justify-between gap-6"
      >
        <div class="max-w-xl">
          <span
            class="text-xs font-bold text-blue-500 dark:text-blue-400 uppercase tracking-[0.2em] mb-2 block"
            >Opiniones</span
          >
          <h2
            class="text-3xl md:text-4xl font-normal tracking-tight text-[hsl(var(--fg))] font-headline leading-tight"
          >
            Lo que dicen mis clientes
          </h2>
        </div>
        <p
          class="text-sm text-[hsl(var(--fg-muted))] max-w-[40ch] leading-relaxed"
        >
          Reseñas reales y opiniones verificadas de usuarios en Google Maps.
        </p>
      </div>
      <Reviews client:visible />
    </div>
  </section>

  <Contact />

  <WhatsAppButton client:visible />
</Layout>
