---
// Specs - Clean 3-column trust factors section
const specs = [
  {
    index: "01",
    title: "Diagnóstico Rápido",
    desc: "Reviso tu televisor o computadora y te digo enseguida qué tiene y cuánto sale arreglarlo.",
  },
  {
    index: "02",
    title: "Trabajo Garantizado",
    desc: "Si algo falla después de la reparación, lo solucionamos sin costo extra.",
  },
  {
    index: "03",
    title: "Atención Personalizada",
    desc: "Te atiendo yo mismo, de principio a fin, sin intermediarios.",
  },
];
---

<section class="relative py-12 sm:py-16 bg-transparent transition-colors duration-300 border-t border-[var(--section-divider)]">
  <div class="mx-auto max-w-[90rem] px-8 sm:px-12 lg:px-20 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 lg:gap-16 w-full">
      {
        specs.map((spec) => (
          <div data-reveal class="flex gap-4 items-start group">
            <span class="font-mono text-sm font-bold text-blue-500 dark:text-[#00b4ff] select-none pt-0.5 whitespace-nowrap">
              {spec.index} //
            </span>
            <div>
              <h4 class="text-base font-semibold text-[hsl(var(--fg))] group-hover:text-blue-500 dark:group-hover:text-[#00b4ff] transition-colors duration-200">
                {spec.title}
              </h4>
              <p class="text-sm text-[hsl(var(--fg-muted))] leading-relaxed mt-2">
                {spec.desc}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
