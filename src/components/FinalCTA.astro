---
// FinalCTA - Asymmetric high-end Call to Action with deep radial glow and gradient border card
---

<section class="relative py-24 overflow-hidden bg-transparent transition-colors duration-300">

  <div class="mx-auto max-w-[90rem] px-8 sm:px-12 lg:px-20 relative z-10">

    {/* Gradient border shell via p-px background gradient trick */}
    <div class="relative rounded-[3rem] p-px overflow-hidden group" style="background: linear-gradient(135deg, rgba(37,99,235,0.4) 0%, rgba(37,99,235,0.05) 40%, rgba(14,165,233,0.12) 70%, rgba(37,99,235,0.3) 100%);">

      {/* Inner fill */}
      <div class="relative rounded-[calc(3rem-1px)] overflow-hidden" style="background: linear-gradient(135deg, #050d1f 0%, #060f26 35%, #091530 65%, #040b1c 100%);">

        {/* Deep directional glow behind data block (right side) */}
        <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 w-[480px] h-[480px] bg-blue-600/[0.14] rounded-full blur-[120px] pointer-events-none transition-transform duration-1000 group-hover:scale-110"></div>
        {/* Secondary ambient glow left/center */}
        <div class="absolute -top-32 left-1/4 w-[350px] h-[350px] bg-cyan-500/[0.06] rounded-full blur-[100px] pointer-events-none"></div>
        {/* Bottom glow */}
        <div class="absolute -bottom-24 left-1/3 w-[300px] h-[300px] bg-blue-800/[0.12] rounded-full blur-[90px] pointer-events-none"></div>

        {/* Inner content */}
        <div class="relative z-10 p-10 sm:p-16">
          <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
            
            {/* Left Column: Eyebrow, Title and Description (lg:col-span-7) */}
            <div class="lg:col-span-7 text-left space-y-6">
              <span class="text-xs font-bold text-blue-500 dark:text-blue-400 uppercase tracking-[0.2em] block">Soporte Inmediato</span>
              
              <h2 class="text-3xl sm:text-5xl font-normal tracking-tight text-white font-headline leading-[1.1]">
                ¿Listo para reparar tu equipo?
              </h2>
              
              <p class="text-sm sm:text-base text-blue-100/50 leading-relaxed max-w-[48ch]">
                Contactanos hoy y obtené un diagnóstico gratuito. Sin compromisos, sin sorpresas. Traelo al taller o solicitalo de forma remota.
              </p>
            </div>

            {/* Right Column: Trust code box + Actions stacked (lg:col-span-5) */}
            <div class="lg:col-span-5 flex flex-col items-center lg:items-end justify-center gap-6 w-full">
              
              {/* Tech-Lab Trust Scorecard — with its own inner glow */}
              <div class="w-full max-w-[300px] relative rounded-2xl p-5 font-mono text-[10px] text-blue-400 space-y-2 select-none overflow-hidden"
                   style="background: rgba(37,99,235,0.06); border: 1px solid rgba(37,99,235,0.18); backdrop-filter: blur(12px);">
                {/* Glow behind scorecard */}
                <div class="absolute inset-0 rounded-2xl bg-blue-600/[0.04] pointer-events-none"></div>
                <div class="relative z-10 space-y-2">
                  <div class="flex justify-between border-b border-blue-500/10 pb-2">
                    <span>// CERTIFICADO</span>
                    <span class="text-white font-bold">OFICIAL_OK</span>
                  </div>
                  <div class="flex justify-between border-b border-blue-500/10 pb-2">
                    <span>// GARANTIA</span>
                    <span class="text-white font-bold">90_DIAS</span>
                  </div>
                  <div class="flex justify-between border-b border-blue-500/10 pb-2">
                    <span>// DIAGNOSTICO</span>
                    <span class="text-white font-bold">0_ARS</span>
                  </div>
                  <div class="flex justify-between">
                    <span>// SISTEMA</span>
                    <span class="text-emerald-400 font-bold">DISPONIBLE</span>
                  </div>
                </div>
              </div>

              {/* Action buttons wrapper */}
              <div class="flex flex-col sm:flex-row lg:flex-col gap-3.5 w-full max-w-[300px]">
                
                {/* Primary WhatsApp Action */}
                <a
                  href="https://wa.me/5492236229328"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group/btn relative w-full inline-flex h-11 items-center justify-between rounded-full bg-[#25D366] text-white text-[11px] font-bold uppercase tracking-wider pl-6 pr-2 py-1.5 gap-4 shadow-md shadow-emerald-500/15 hover:opacity-95 active:scale-[0.98] transition-all"
                >
                  <span>Chateá por WhatsApp</span>
                  <div class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center transform group-hover/btn:translate-x-0.5 transition-transform duration-300">
                    <svg class="w-3.5 h-3.5 fill-white" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                    </svg>
                  </div>
                </a>

                {/* Secondary Form Action */}
                <a
                  href="#contacto"
                  class="w-full inline-flex h-11 items-center justify-center rounded-full text-white text-[11px] font-bold uppercase tracking-wider transition-all active:scale-[0.98]"
                  style="border: 1px solid rgba(37,99,235,0.25); background: rgba(37,99,235,0.08);"
                  onmouseover="this.style.background='rgba(37,99,235,0.16)'"
                  onmouseout="this.style.background='rgba(37,99,235,0.08)'"
                >
                  Completar formulario
                </a>

              </div>

            </div>

          </div>
        </div>

        {/* Bottom fade to merge with footer — gradual, no hard edge */}
        <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(to right, transparent, rgba(37,99,235,0.2) 30%, rgba(14,165,233,0.15) 60%, transparent);"></div>
      </div>
    </div>

  </div>
</section>
