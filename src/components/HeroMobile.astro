---
// HeroMobile - Exclusivo para pantallas móviles y tablets (< lg)
import { getBusinessStatus } from "../lib/businessHours";
const { isOpen, badgeText } = getBusinessStatus();
---

<!-- 
  =========================================
  HERO MOBILE CONTAINER (< lg)
  =========================================
-->
<section
  class="lg:hidden relative h-[calc(100dvh-4rem)] w-full flex flex-col justify-between overflow-hidden bg-gradient-to-b from-[#020816] via-[#071638] to-[#050b14]"
>
  {/* Local tech grid overlay */}
  <div
    class="absolute inset-0 z-0 pointer-events-none select-none"
    style="background-image: linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 50px 50px;"
  >
  </div>

  {
    /* Ambient tech-glow orbs (radial glow matching the AGR Electrónica colors) */
  }
  <div
    class="absolute top-[-20%] left-1/2 -translate-x-1/2 w-[700px] h-[700px] bg-[#00a2ff]/15 rounded-full blur-[140px] pointer-events-none z-0"
  >
  </div>
  <div
    class="absolute top-[20%] left-[10%] w-[350px] h-[350px] bg-[#00f5ff]/8 rounded-full blur-[100px] pointer-events-none z-0"
  >
  </div>
  <div
    class="absolute bottom-[10%] right-[5%] w-[400px] h-[400px] bg-[#0055ff]/8 rounded-full blur-[120px] pointer-events-none z-0"
  >
  </div>

  {/* MOBILE HERO CONTAINER CONTENT */}
  <div
    class="relative z-10 w-full h-full flex flex-col justify-between mx-auto"
  >
    {
      /* CONTENIDO PRINCIPAL (Centrado verticalmente entre navbar y footer de estado) */
    }
    <div
      data-stagger
      class="flex-1 flex flex-col items-center justify-center text-center space-y-6 px-6 py-6 w-full max-w-md sm:max-w-lg mx-auto"
    >
      {
        /* 1. Overline con Horario únicamente (sin punto ni palabra Abierto) y líneas decorativas */
      }
      <div
        data-reveal
        class="hero-stagger-item flex flex-col items-center gap-4 w-full"
      >
        {/* Overline de horario enmarcado con líneas decorativas */}
        <div
          class="flex items-center justify-center gap-2.5 mb-0.5 whitespace-nowrap max-w-full overflow-hidden"
        >
          <span class="w-4 sm:w-7 h-[1px] bg-blue-400/40 shrink-0"></span>
          <span
            id="hero-status-time-mobile"
            class={`text-[11px] sm:text-xs font-mono font-bold tracking-[0.15em] uppercase shrink-0 ${isOpen ? "text-blue-200" : "text-slate-300"}`}
          >
            {badgeText.split(" — ")[1]}
          </span>
          <span class="w-4 sm:w-7 h-[1px] bg-blue-400/40 shrink-0"></span>
        </div>

        <h1
          class="font-headline text-[2.15rem] sm:text-4xl font-bold leading-[1.12] tracking-tight text-white uppercase"
        >
          AGR ELECTRÓNICA <br />
          <span
            class="gradient-shiny animate-shiny text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300 font-extrabold uppercase text-[2.15rem] sm:text-4xl"
          >
            SERVICIO TÉCNICO
          </span>
        </h1>

        {/* 2. Texto descriptivo */}
        <p
          class="text-xs sm:text-sm leading-relaxed text-blue-100/80 max-w-[32ch] sm:max-w-[38ch] pt-1"
        >
          ¿Tu equipo no prende o anda lento? Dejá tu televisor o computadora en
          manos capacitadas.
        </p>
      </div>

      {/* 3. ÚNICO BOTÓN PRINCIPAL CENTRADO (Pedir diagnóstico) - ANGOSTO */}
      <div
        data-reveal
        class="hero-stagger-item flex items-center justify-center w-full pt-2"
      >
        <a
          href="#contacto"
          class="btn-press inline-flex h-11 sm:h-12 items-center justify-center rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-xs sm:text-sm font-semibold px-7 sm:px-8 shadow-md shadow-blue-600/20 active:scale-[0.98] transition-all gap-2.5 whitespace-nowrap"
        >
          <span class="whitespace-nowrap">Pedir diagnóstico</span>
          <svg
            class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-white shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </div>

    {
      /* BARRA INFERIOR DE 3 COLUMNAS (Col 1 Izq 64px | Col 2 Centro 1fr | Col 3 Der 64px) */
    }
    <div
      class="shrink-0 w-full h-16 border-t border-blue-500/20 bg-[#030919]/95 backdrop-blur-md grid grid-cols-[64px_1fr_64px] items-center select-none"
    >
      {
        /* Columna 1 (Izq, 64px): Punto de estado + texto ABIERTO con borde derecho */
      }
      <div
        id="hero-status-badge-mobile"
        class="flex flex-col items-center justify-center gap-1 w-16 h-16 border-r border-blue-500/20 shrink-0"
      >
        <span class="relative flex h-2 w-2 shrink-0">
          <span
            id="hero-status-ping-mobile"
            class={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${isOpen ? "bg-emerald-400" : "bg-rose-400"}`}
          ></span>
          <span
            id="hero-status-dot-mobile"
            class={`relative inline-flex rounded-full h-2 w-2 ${isOpen ? "bg-emerald-500" : "bg-rose-500"}`}
          ></span>
        </span>
        <span
          id="hero-status-label-mobile"
          class={`text-[9px] font-mono font-bold tracking-wider uppercase truncate ${isOpen ? "text-emerald-400" : "text-rose-400"}`}
        >
          {badgeText.split(" — ")[0]}
        </span>
      </div>

      {/* Columna 2 (Centro, 1fr): MAR DEL PLATA centrado */}
      <div class="flex items-center justify-center gap-2 px-2 h-full min-w-0">
        <span class="w-4 h-[1px] bg-blue-400/40 shrink-0"></span>
        <span
          class="text-xs font-mono font-bold tracking-[0.25em] text-blue-300/70 uppercase truncate text-center"
        >
          MAR DEL PLATA
        </span>
        <span class="w-4 h-[1px] bg-blue-400/40 shrink-0"></span>
      </div>

      {
        /* Columna 3 (Der, 64px): Botón de WhatsApp centrado con borde izquierdo */
      }
      <div
        class="flex items-center justify-center w-16 h-16 border-l border-blue-500/20 shrink-0"
      >
        <a
          href="https://wa.me/5492236229328"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full h-full flex items-center justify-center text-white/90 hover:text-emerald-400 active:bg-white/10 transition-colors"
          aria-label="Contactar por WhatsApp"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { getBusinessStatus } from "../lib/businessHours";

  function updateMobileHeroStatus() {
    const { isOpen, badgeText } = getBusinessStatus();
    const ping = document.getElementById("hero-status-ping-mobile");
    const dot = document.getElementById("hero-status-dot-mobile");
    const labelEl = document.getElementById("hero-status-label-mobile");
    const timeEl = document.getElementById("hero-status-time-mobile");

    if (ping) {
      ping.className = `animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${isOpen ? "bg-emerald-400" : "bg-rose-400"}`;
    }

    if (dot) {
      dot.className = `relative inline-flex rounded-full h-2 w-2 ${isOpen ? "bg-emerald-500" : "bg-rose-500"}`;
    }

    if (labelEl) {
      labelEl.textContent = badgeText.split(" — ")[0];
      labelEl.className = `text-[9px] font-mono font-bold tracking-wider uppercase truncate ${isOpen ? "text-emerald-400" : "text-rose-400"}`;
    }

    if (timeEl) {
      timeEl.textContent = badgeText.split(" — ")[1];
      timeEl.className = `text-[11px] sm:text-xs font-mono font-bold tracking-[0.15em] uppercase shrink-0 ${isOpen ? "text-blue-200" : "text-slate-300"}`;
    }
  }

  updateMobileHeroStatus();
  setInterval(updateMobileHeroStatus, 60000);
</script>
