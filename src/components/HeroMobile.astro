---
// HeroMobile - Exclusivo para pantallas móviles y tablets (< lg)
import { getBusinessStatus } from "../lib/businessHours";
const { isOpen, badgeText } = getBusinessStatus();
---

<!-- 
  =========================================
  HERO MOBILE CONTAINER (< lg)
  =========================================
-->
<section
  class="lg:hidden relative h-[100svh] w-full flex flex-col justify-between bg-transparent pt-14"
>
  {/* MOBILE HERO CONTAINER CONTENT */}
  <div
    class="relative z-10 w-full h-full flex flex-col justify-between mx-auto"
  >
    {
      /* CONTENIDO PRINCIPAL (Centrado verticalmente entre navbar y barra intermedia) */
    }
    <div
      data-stagger
      class="flex-1 flex flex-col items-center justify-center text-center space-y-6 px-6 py-6 w-full max-w-md sm:max-w-lg mx-auto"
    >
      {
        /* 1. Overline con Horario únicamente y líneas decorativas */
      }
      <div
        data-reveal
        class="hero-stagger-item flex flex-col items-center gap-4 w-full"
      >
        {/* Overline de horario enmarcado con líneas decorativas adaptativas */}
        <div
          class="flex items-center justify-center gap-1.5 sm:gap-2.5 mb-0.5 whitespace-nowrap max-w-full overflow-hidden px-1"
        >
          <span class="w-2 sm:w-7 h-[1px] bg-blue-400/40 shrink min-w-0 max-[330px]:hidden"></span>
          <span
            id="hero-status-time-mobile"
            class={`text-[11px] sm:text-xs font-mono font-bold tracking-[0.15em] uppercase shrink-0 ${isOpen ? "text-blue-200" : "text-slate-300"}`}
          >
            {badgeText.split(" — ")[1]}
          </span>
          <span class="w-2 sm:w-7 h-[1px] bg-blue-400/40 shrink min-w-0 max-[330px]:hidden"></span>
        </div>

        <h1
          class="font-headline text-[clamp(1.6rem,7.5vw,2.25rem)] sm:text-4xl font-bold leading-[1.12] tracking-tight text-white uppercase w-full"
        >
          <span class="block whitespace-nowrap">AGR&nbsp;ELECTRÓNICA</span>
          <span
            class="block whitespace-nowrap gradient-shiny animate-shiny text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300 font-extrabold uppercase text-[clamp(1.6rem,7.5vw,2.25rem)] sm:text-4xl"
          >
            SERVICIO&nbsp;TÉCNICO
          </span>
        </h1>

        {/* 2. Texto descriptivo */}
        <p
          class="text-xs sm:text-sm leading-relaxed text-white/85 max-w-[32ch] sm:max-w-[38ch] pt-1"
        >
          Soluciones rápidas para tu computadora o TV.
        </p>
      </div>

      {/* 3. ÚNICO BOTÓN PRINCIPAL CENTRADO (Pedir diagnóstico) */}
      <div
        data-reveal
        class="hero-stagger-item flex items-center justify-center w-full pt-2"
      >
        <a
          href="#contacto"
          class="btn-press inline-flex h-11 sm:h-12 items-center justify-center rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-xs sm:text-sm font-semibold px-7 sm:px-8 shadow-md shadow-blue-600/20 active:scale-[0.98] transition-all gap-2.5 whitespace-nowrap"
        >
          <span class="whitespace-nowrap">Pedir diagnóstico</span>
          <svg
            class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-white shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </div>

    {
      /* BARRA INTERMEDIA TRANSLÚCIDA SIN BORDES VERTICALES RÍGIDOS */
    }
    <div
      class="shrink-0 w-full h-14 border-y border-black/5 dark:border-white/10 bg-white/80 dark:bg-[#020816]/80 backdrop-blur-md grid grid-cols-[56px_1fr_56px] items-center select-none"
    >
      {
        /* Columna 1 (Izq, 56px): Punto de estado + texto ABIERTO */
      }
      <div
        id="hero-status-badge-mobile"
        class="flex flex-col items-center justify-center gap-1 w-14 h-14 shrink-0 border-r border-black/5 dark:border-white/10"
      >
        <span class="relative flex h-2 w-2 shrink-0">
          <span
            id="hero-status-ping-mobile"
            class={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${isOpen ? "bg-emerald-400" : "bg-rose-400"}`}
          ></span>
          <span
            id="hero-status-dot-mobile"
            class={`relative inline-flex rounded-full h-2 w-2 ${isOpen ? "bg-emerald-500" : "bg-rose-500"}`}
          ></span>
        </span>
        <span
          id="hero-status-label-mobile"
          class={`text-[9px] font-mono font-bold tracking-wider uppercase truncate ${isOpen ? "text-emerald-400" : "text-rose-400"}`}
        >
          {badgeText.split(" — ")[0]}
        </span>
      </div>

      {/* Columna 2 (Centro, 1fr): MAR DEL PLATA centrado */}
      <div class="flex items-center justify-center gap-1.5 sm:gap-2 px-1 sm:px-2 h-full min-w-0">
        <span class="w-2 sm:w-4 h-[1px] bg-white/30 shrink min-w-0 max-[340px]:hidden"></span>
        <span
          class="text-[10.5px] min-[360px]:text-xs font-mono font-bold tracking-[0.15em] min-[360px]:tracking-[0.25em] text-white uppercase truncate text-center"
        >
          MAR DEL PLATA
        </span>
        <span class="w-2 sm:w-4 h-[1px] bg-white/30 shrink min-w-0 max-[340px]:hidden"></span>
      </div>

      {
        /* Columna 3 (Der, 56px): Botón de WhatsApp centrado */
      }
      <div
        class="flex items-center justify-center w-14 h-14 shrink-0 border-l border-black/5 dark:border-white/10"
      >
        <a
          href="https://wa.me/5492236229328"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full h-full flex items-center justify-center text-white/90 hover:text-emerald-400 active:bg-white/10 transition-colors"
          aria-label="Contactar por WhatsApp"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { getBusinessStatus } from "../lib/businessHours";

  function updateMobileHeroStatus() {
    const { isOpen, badgeText } = getBusinessStatus();
    const ping = document.getElementById("hero-status-ping-mobile");
    const dot = document.getElementById("hero-status-dot-mobile");
    const labelEl = document.getElementById("hero-status-label-mobile");
    const timeEl = document.getElementById("hero-status-time-mobile");

    if (ping) {
      ping.className = `animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${isOpen ? "bg-emerald-400" : "bg-rose-400"}`;
    }

    if (dot) {
      dot.className = `relative inline-flex rounded-full h-2 w-2 ${isOpen ? "bg-emerald-500" : "bg-rose-500"}`;
    }

    if (labelEl) {
      labelEl.textContent = badgeText.split(" — ")[0];
      labelEl.className = `text-[9px] font-mono font-bold tracking-wider uppercase truncate ${isOpen ? "text-emerald-400" : "text-rose-400"}`;
    }

    if (timeEl) {
      timeEl.textContent = badgeText.split(" — ")[1];
      timeEl.className = `text-[11px] sm:text-xs font-mono font-bold tracking-[0.15em] uppercase shrink-0 ${isOpen ? "text-blue-200" : "text-slate-300"}`;
    }
  }

  updateMobileHeroStatus();
  setInterval(updateMobileHeroStatus, 60000);
</script>
